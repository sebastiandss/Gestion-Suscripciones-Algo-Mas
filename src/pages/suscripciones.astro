---
import MainLayout from '../layout/MainLayout.astro';
import FilterBar from '../components/FilterBar.astro';
import SubscriptionsGrid from '../components/SubscriptionsGrid.astro';

// Dejamos el arreglo vacío
const allSubscriptions = []; 
---

<MainLayout>
    <div class="header-section">
        <div class="title-info">
            <h1>Suscripciones</h1>
            <p>Monitoreo de gastos fijos</p>
        </div>
    </div>

    <FilterBar />

    <SubscriptionsGrid subscriptions={allSubscriptions} />
</MainLayout>

<style>
    .header-section {
        margin-bottom: 20px; 
    }
    .title-info h1 { font-size: 2.2rem; font-weight: 700; color: white; margin-bottom: 8px; }
    .title-info p { color: #666; font-size: 1rem; letter-spacing: 0.5px; }
</style>