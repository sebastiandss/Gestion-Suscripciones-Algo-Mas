---
import SubscriptionCard from './SubscriptionCard.astro';
---

<div class="carousel-header">
    <h2 class="section-title">Tus Suscripciones</h2>
</div>

<div class="carousel-wrapper">
    <div class="carousel-viewport">
        <div class="subscriptions-track" id="track">
            <SubscriptionCard name="Spotify" price="$9.99/mes" serviceClass="spotify" />
            <SubscriptionCard name="Netflix" price="$15.90/mes" serviceClass="netflix" />
            <SubscriptionCard name="Max (HBO)" price="$14.99/mes" serviceClass="hbo" />
            <SubscriptionCard name="Prime Video" price="$14.99/año" serviceClass="prime" />
            <SubscriptionCard name="Disney+" price="$7.99/mes" serviceClass="disney" />
            <SubscriptionCard name="YouTube" price="$11.99/mes" serviceClass="youtube" />
            <SubscriptionCard name="Steam" price="Variable" serviceClass="steam" />
        </div>
    </div>

    <button class="nav-arrow left" id="prevBtn" aria-label="Anterior">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="nav-arrow right" id="nextBtn" aria-label="Siguiente">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
</div>

<script>
    const track = document.getElementById('track');
    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');
    let pos = 0;
    const step = 260; 

    nextBtn?.addEventListener('click', () => {
        const max = -(track.scrollWidth - track.parentElement.clientWidth);
        pos -= step * 2;
        if (pos < max) pos = max;
        track.style.transform = `translateX(${pos}px)`;
    });

    prevBtn?.addEventListener('click', () => {
        pos += step * 2;
        if (pos > 0) pos = 0;
        track.style.transform = `translateX(${pos}px)`;
    });
</script>

<style>
    /* Estilos para el encabezado de sección */
    .carousel-header {
        margin-bottom: 15px;
        padding: 0 5px;
    }
    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #eee;
    }

    /* Estilos del contenedor principal */
    .carousel-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 35px;
        display: flex; /* Cambiado para alinear elementos */
        align-items: center;
        /* Añadimos padding lateral para que las flechas tengan espacio */
        padding: 0 45px; 
    }

    .carousel-viewport {
        width: 100%;
        overflow: hidden; /* Importante para ocultar las tarjetas extra */
        padding: 15px 5px; /* Espacio para las sombras del hover */
    }

    .subscriptions-track {
        display: flex;
        gap: 20px;
        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1); /* Animación suave */
        will-change: transform;
    }

    /* Estilos para las flechas de navegación */
    .nav-arrow {
        position: absolute; /* Posicionamiento respecto a .carousel-wrapper */
        width: 36px;
        height: 36px;
        border-radius: 50%;
        top: 50%; /* Centrado vertical */
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.03); /* Fondo sutil */
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: #666;
        z-index: 10;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Efectos hover para las flechas */
    .nav-arrow:hover {
        background: rgba(59, 130, 246, 0.1);
        border-color: rgba(59, 130, 246, 0.2);
        color: #3b82f6;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
    }

    /* Posicionamiento específico (izquierda/derecha) */
    .left {
        left: 0; /* Pegado al borde izquierdo del wrapper */
    }

    .right {
        right: 0; /* Pegado al borde derecho del wrapper */
    }
</style>