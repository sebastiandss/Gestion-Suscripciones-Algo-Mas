<div class="view-switches">
    <button id="grid-view" class="switch-btn active">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
    </button>
    <button id="list-view" class="switch-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
    </button>
</div>

<style>
    .view-switches {
        display: flex;
        gap: 6px; /* Espacio entre los dos botones */
    }

    .switch-btn {
        background: transparent;
        border: none;
        color: #555; /* Color grisáceo para no resaltar de más */
        padding: 6px;
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
    }

    .switch-btn:hover {
        color: #eee;
        background: rgba(255, 255, 255, 0.05);
    }
    
    .switch-btn.active {
        color: #3b82f6;
        background: rgba(59, 130, 246, 0.1); /* Fondo azul muy sutil */
    }

</style>