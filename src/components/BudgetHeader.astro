---
/* src/components/BudgetHeader.astro */
---
<header class="budget-header">
    <div class="title-area">
        <div class="icon-bg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="text">
            <h2>Presupuesto y Alertas</h2>
            <p>Control de límites y notificaciones</p>
        </div>
    </div>

    <div class="actions">
        <div class="date-pill">Marzo 2026</div>
        <button class="btn-budget" id="open-budget-modal">
            <span>+</span> Nuevo presupuesto
        </button>
    </div>
</header>

<style>
    .budget-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 40px;
        background: transparent;
    }

    .title-area {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .icon-bg {
        width: 45px;
        height: 45px;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }

    .text h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: white;
        margin: 0;
    }

    .text p {
        font-size: 0.85rem;
        color: #555;
        margin: 0;
    }

    .actions {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .date-pill {
        background: rgba(255, 255, 255, 0.03);
        padding: 10px 20px;
        border-radius: 30px;
        font-size: 0.85rem;
        color: #888;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-budget {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-budget span {
        font-size: 1.2rem;
    }

    .btn-budget:hover {
        background: #2563eb;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }
</style>