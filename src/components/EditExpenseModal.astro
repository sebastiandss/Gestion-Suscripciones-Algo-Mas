---
/* Tu HTML del modal se queda igual */
---
<div id="modal-expense" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h2>Editar Gasto Mensual</h2>
            <button id="close-expense" class="close-x">&times;</button>
        </div>

        <form id="form-expense">
            <div class="field">
                <label>Nuevo Valor Mensual</label>
                <input type="number" id="input-expense" placeholder="0.00" step="0.01" required />
            </div>
            <button type="submit" class="btn-update">Actualizar Valor</button>
        </form>
    </div>
</div>

<script>
    // 1. Primero definimos las variables para que el código las reconozca
    const modal = document.getElementById('modal-expense');
    const closeBtn = document.getElementById('close-expense');
    const form = document.getElementById('form-expense') as HTMLFormElement;

    // 2. Lógica para cerrar el modal (opcional, pero recomendada)
    closeBtn?.addEventListener('click', () => {
        modal?.classList.remove('active');
    });

    // 3. AQUÍ VA EL CÓDIGO QUE ME PREGUNTASTE:
    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Buscamos el input por su ID
        const input = document.getElementById('input-expense') as HTMLInputElement;
        const valorIngresado = input.value;

        // Disparamos el evento con el valor para que StatSection lo escuche
        window.dispatchEvent(new CustomEvent('update-expense', { 
            detail: { valor: valorIngresado } 
        }));

        // Cerramos y reseteamos
        modal?.classList.remove('active');
        form.reset();
    });
</script>

<style>
    /* ... tus estilos del modal ... */
    .modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.8);
        display: none; justify-content: center; align-items: center;
        z-index: 10000; backdrop-filter: blur(8px);
    }
    .modal-overlay.active { display: flex; }
    /* ... resto de estilos ... */
</style>