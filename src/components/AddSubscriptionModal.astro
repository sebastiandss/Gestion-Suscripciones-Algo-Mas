---
/* src/components/AddSubscriptionModal.astro */
---
<div id="modal-overlay" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Nueva Suscripción</h2>
      <button id="close-modal" class="close-btn" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <form class="modal-form" id="sub-form">
      <div class="input-group">
        <label>Nombre del servicio</label>
        <input type="text" placeholder="Ej. Netflix, Spotify..." id="sub-name" required />
      </div>

      <div class="input-group">
        <label>Etiqueta (Categoría)</label>
        <input 
          type="text" 
          id="sub-tag" 
          list="categories-list" 
          placeholder="Escribe o selecciona..." 
        />
        <datalist id="categories-list">
          <option value="Entretenimiento"></option>
          <option value="Streaming"></option>
          <option value="Trabajo"></option>
          <option value="Servicios"></option>
          <option value="Salud"></option>
          <option value="Videojuegos"></option>
          <option value="Música"></option>
        </datalist>
      </div>

      <div class="input-row">
        <div class="input-group">
          <label>Precio</label>
          <input type="text" placeholder="$0.00" id="sub-price" required />
        </div>
        <div class="input-group">
          <label>Fecha de pago</label>
          <input type="date" id="sub-date" />
        </div>
      </div>

      <div class="input-group">
        <label>Color de marca</label>
        <div class="color-picker">
            <label class="color-option">
              <input type="radio" name="color" value="blue" checked />
              <span class="dot blue"></span>
            </label>
            <label class="color-option">
              <input type="radio" name="color" value="green" />
              <span class="dot green"></span>
            </label>
            <label class="color-option">
              <input type="radio" name="color" value="purple" />
              <span class="dot purple"></span>
            </label>
            <label class="color-option">
              <input type="radio" name="color" value="red" />
              <span class="dot red"></span>
            </label>
            <label class="color-option">
              <input type="radio" name="color" value="orange" />
              <span class="dot orange"></span>
            </label>
        </div>
      </div>

      <button type="button" class="btn-save" id="save-sub-btn">Guardar suscripción</button>
    </form>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(8px);
    display: none; justify-content: center; align-items: center; z-index: 1000;
  }
  .modal-overlay.is-active { display: flex; }

  .modal-content {
    background: #1a1a1a; width: 90%; max-width: 450px; padding: 30px;
    border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  /* HEADER ALINEADO */
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  .modal-header h2 {
    color: white; font-size: 1.4rem; font-weight: 700; margin: 0;
  }

  /* BOTÓN CERRAR ESTÉTICO */
  .close-btn {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #666;
    width: 32px; height: 32px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s ease; padding: 0;
  }

  .close-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
    transform: rotate(90deg);
  }

  /* FORMULARIO E INPUTS */
  .modal-form { display: flex; flex-direction: column; gap: 20px; }
  .input-group { display: flex; flex-direction: column; gap: 8px; }
  .input-group label { font-size: 0.8rem; color: #888; font-weight: 600; text-transform: uppercase; }
  
  input { 
    background: #222; border: 1px solid #333; padding: 12px; 
    border-radius: 12px; color: white; outline: none; 
  }
  input:focus { border-color: #3b82f6; }

  input::-webkit-calendar-picker-indicator {
    filter: invert(1); opacity: 0.4; cursor: pointer;
  }

  .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
  
  /* COLOR PICKER */
  .color-picker { display: flex; gap: 15px; }
  .color-option input { display: none; }
  .dot { width: 32px; height: 32px; border-radius: 50%; display: block; cursor: pointer; border: 3px solid transparent; transition: 0.2s; }
  .color-option input:checked + .dot { border-color: white; transform: scale(1.1); }
  
  .blue { background: #3b82f6; } .green { background: #22c55e; } 
  .purple { background: #a855f7; } .red { background: #ef4444; } 
  .orange { background: #f97316; }

  .btn-save { 
    background: #3b82f6; color: white; border: none; padding: 15px; 
    border-radius: 14px; font-weight: 700; cursor: pointer; margin-top: 10px;
    transition: background 0.2s;
  }
  .btn-save:hover { background: #2563eb; }
</style>

<script>
  import { addSubscription } from '../store/subsStore.js';

  const setupModal = () => {
    const modal = document.getElementById('modal-overlay');
    const closeBtn = document.getElementById('close-modal');
    const saveBtn = document.getElementById('save-sub-btn');
    const form = document.getElementById('sub-form') as HTMLFormElement;

    // Abrir
    window.addEventListener('abrir-modal-suscripcion', () => {
      modal?.classList.add('is-active');
    });

    // Cerrar
    closeBtn?.addEventListener('click', () => modal?.classList.remove('is-active'));

    // Guardar
    saveBtn?.addEventListener('click', () => {
      const name = (document.getElementById('sub-name') as HTMLInputElement).value;
      const tag = (document.getElementById('sub-tag') as HTMLInputElement).value;
      const price = (document.getElementById('sub-price') as HTMLInputElement).value;
      const date = (document.getElementById('sub-date') as HTMLInputElement).value;
      const color = (document.querySelector('input[name="color"]:checked') as HTMLInputElement).value;

      if (!name || !price) {
          alert("Por favor completa nombre y precio");
          return;
      }

      addSubscription({ 
        name, 
        tag: tag || 'General', 
        price: price.replace('$', ''), 
        date, 
        serviceClass: color,
        status: 'Activo' 
      });

      form.reset();
      modal?.classList.remove('is-active');
    });
  };

  // Inicializar
  setupModal();
  document.addEventListener('astro:after-swap', setupModal);
</script>