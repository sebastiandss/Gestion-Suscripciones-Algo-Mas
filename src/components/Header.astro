<header class="top-header">
    <div class="title-area">
        <h2>Dashboard</h2>
        <div class="status-dot"></div>
    </div>

    <div class="actions">
        <div class="date-pill" id="current-date-pill">Cargando...</div>
        <button id="open-modal" class="btn-new">+ Nueva suscripcion</button>
    </div>
</header>

<script>
    const setupHeader = () => {
        // 1. Lógica de la fecha
        const dateElement = document.getElementById('current-date-pill');
        if (dateElement) {
            const ahora = new Date();
            const mesYAnio = ahora.toLocaleDateString('es-ES', {
                month: 'long',
                year: 'numeric'
            });
            dateElement.textContent = mesYAnio.charAt(0).toUpperCase() + mesYAnio.slice(1);
        }

        // 2. Lógica del botón (Moverla AQUÍ adentro es la clave)
        const openModalBtn = document.getElementById('open-modal');
        
        // Eliminamos cualquier listener previo para no duplicar y agregamos el nuevo
        openModalBtn?.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('abrir-modal-suscripcion'));
        });
    };

    // Ejecutar al cargar la primera vez
    setupHeader();

    // Re-ejecutar cada vez que ClientRouter cambie la página
    document.addEventListener('astro:after-swap', setupHeader);
</script>

<style>
    /* Mantenemos tus estilos EXACTAMENTE igual */
    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 40px;
        background-color: transparent; 
    }

    .title-area {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .title-area h2 {
        font-size: 1.8rem;
        font-weight: 700;
        color: white; /* Aseguramos visibilidad en modo oscuro */
    }

    .status-dot {
        width: 10px;
        height: 10px;
        background-color: #22c55e;
        border-radius: 50%;
        box-shadow: 0 0 12px rgba(34, 197, 94, 0.6);
        margin-top: 5px;
    }

    .actions {
        display: flex;
        gap: 15px;
    }

    .date-pill {
        background: rgba(255, 255, 255, 0.05);
        padding: 10px 20px;
        border-radius: 30px;
        font-size: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        color: white;
    }

    .btn-new {
        background: #ffffff;
        color: #000000;
        border: none;
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .btn-new:hover {
        transform: scale(1.05);
    }
</style>