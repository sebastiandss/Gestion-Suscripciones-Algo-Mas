---
// Lógica para detectar la página activa
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1).replace(/\/$/, ""); 
---

<aside class="sidebar" id="sidebar">
    <div class="logo-section">
        <div class="logo-icon">S</div>
        <div class="logo-text">
            <h1>SubTrack</h1>
            <span>v1.0</span>
        </div>
    </div>

    <nav class="menu">
        <p class="menu-label">PRINCIPAL</p>
        <ul>
            <a href="/" class="nav-link">
                <li class={currentPath === "" ? "active" : ""}>
                    <div class="icon-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                    </div>
                    <span class="nav-text">Dashboard</span>
                </li>
            </a>
            
            <a href="/suscripciones" class="nav-link">
                <li class={currentPath === "suscripciones" ? "active" : ""}>
                    <div class="icon-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <span class="nav-text">Suscripciones</span>
                    <div class="badge-wrapper">
                        <span class="badge" id="subs-count-badge">0</span>
                    </div>
                </li>
            </a>
        </ul>
        <p class="menu-label">PRESUPUESTO</p>
        <ul>
            <a href="/presupuesto" class="nav-link">
                <li class={currentPath === "presupuesto" ? "active" : ""}>
                    <div class="icon-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/>
                            <path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/>
                        </svg>
                    </div>
                    <span class="nav-text">Presupuesto</span>
                </li>
            </a>
        </ul>
    </nav>

    <a href="/perfil" class="nav-link" style="margin-top: auto;">
        <div class={`user-profile ${currentPath === "perfil" ? "active-profile" : ""}`}>
            <div class="avatar">JD</div>
            <div class="user-info">
                <p class="name">Juan Díaz</p>
                <p class="role">Perfil</p>
            </div>
        </div>
    </a>
</aside>

<script>
    import { $subscriptions } from '../store/subsStore.js';
    const updateBadge = () => {
        const badge = document.getElementById('subs-count-badge');
        $subscriptions.subscribe(subs => {
            if (badge) {
                badge.textContent = subs.length.toString();
                badge.style.display = subs.length === 0 ? 'none' : 'inline-flex';
            }
        });
    };
    updateBadge();
    document.addEventListener('astro:after-swap', updateBadge);
</script>

<style>
    .sidebar {
        width: 80px;
        background-color: #121212;
        display: flex;
        flex-direction: column;
        padding: 24px 15px;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        white-space: nowrap;
        height: 100vh;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        box-sizing: border-box;
    }

    .sidebar:hover { width: 260px; }

    /* Mantenemos tus iconos y textos */
    .icon-wrapper { min-width: 50px; display: flex; justify-content: center; }
    .nav-text { font-size: 0.9rem; font-weight: 500; flex: 1; }

    .menu li {
        display: flex;
        align-items: center;
        padding: 12px 0;
        border-radius: 12px;
        color: #999;
        margin-bottom: 8px;
        transition: all 0.2s ease;
        width: 100%;
    }

    .menu li.active { background: rgba(37, 99, 235, 0.1); color: #3b82f6; }

    /* LÓGICA DE VISIBILIDAD */
    .nav-text, .badge-wrapper, .logo-text, .menu-label, .user-info {
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s ease;
    }

    .sidebar:hover .nav-text,
    .sidebar:hover .badge-wrapper,
    .sidebar:hover .logo-text,
    .sidebar:hover .menu-label,
    .sidebar:hover .user-info {
        opacity: 1;
        visibility: visible;
    }

    /* EL BADGE CORREGIDO */
    .badge-wrapper {
        margin-left: auto;
        padding-right: 15px;
        display: flex;
        align-items: center;
    }

    .badge {
        background: #2563eb;
        color: white;
        padding: 2px 8px;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 20px;
        justify-content: center;
    }

    /* (Resto de estilos de logo y perfil que ya tenías...) */
    .logo-section { display: flex; align-items: center; gap: 15px; margin-bottom: 40px; }
    .logo-icon { min-width: 50px; height: 50px; background-color: #2563eb; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; }
    .logo-text h1 { font-size: 1.1rem; color: white; margin: 0; }
    .logo-text span { font-size: 0.7rem; color: #444; }
    .user-profile { margin-top: auto; display: flex; align-items: center; padding: 15px 0; border-top: 1px solid rgba(255, 255, 255, 0.05); }
    .avatar { min-width: 50px; height: 50px; background: #2563eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; }
    .user-info { padding-left: 12px; }
    .name { font-size: 0.9rem; font-weight: 600; color: white; margin: 0; }
    .role { font-size: 0.75rem; color: #555; margin: 0; }
    .nav-link { text-decoration: none; color: inherit; }
</style>